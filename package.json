{
  "name": "cursor-orch",
  "version": "0.3.0",
  "description": "CLI to orchestrate multiple Cursor Cloud Agents across GitHub repositories",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cursor-orch": "./dist/cli.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run bundle:runtime",
    "bundle:runtime": "esbuild src/orchestrator-entry.ts --bundle --platform=node --format=cjs --outfile=dist/orchestrator-runtime.cjs --legal-comments=none",
    "prepack": "npm run build",
    "test": "vitest run",
    "smoke": "bun ./dist/cli.js --help",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@crustjs/core": "^0.0.15",
    "@crustjs/plugins": "^0.0.20",
    "chalk": "^5.4.1",
    "jsonrepair": "^3.12.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
