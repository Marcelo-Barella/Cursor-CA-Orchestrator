{
  "name": "cursor-orch",
  "version": "0.6.0",
  "description": "CLI to orchestrate multiple Cursor Cloud Agents across GitHub repositories",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cursor-orch": "dist/cli.js"
  },
  "files": [
    "dist",
    "oclif.manifest.json",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "oclif": {
    "bin": "cursor-orch",
    "dirname": "cursor-orch",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-autocomplete"
    ],
    "topicSeparator": " "
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run bundle:runtime",
    "bundle:runtime": "esbuild src/orchestrator-entry.ts --bundle --platform=node --format=cjs --outfile=dist/orchestrator-runtime.cjs --legal-comments=none",
    "prepack": "npm run build && oclif manifest",
    "test": "vitest run",
    "smoke": "node ./dist/cli.js --help",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@oclif/core": "^4.10.2",
    "@oclif/plugin-autocomplete": "^3.2.42",
    "blessed": "^0.1.81",
    "gpt-tokenizer": "^3.4.0",
    "jsonrepair": "^3.12.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.0",
    "oclif": "^4.22.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
